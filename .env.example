# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080
APP_BASE_URL=http://localhost:8080   # change to https://dreamlog.app in prod

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=dreamlog
POSTGRES_PASSWORD=dreamlog_secret
POSTGRES_DB=dreamlog
DATABASE_URL=postgres://dreamlog:dreamlog_secret@postgres:5432/dreamlog?sslmode=disable

DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=redis:6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0

# ── Storage (MinIO local dev) ─────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret

STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin_secret
STORAGE_BUCKET=dreamlog-audio
STORAGE_REGION=us-east-1
STORAGE_USE_PATH_STYLE=true         # true for MinIO; false for Cloudflare R2/S3
STORAGE_PRESIGN_EXPIRY=15m

# ── Storage (Cloudflare R2 — override in production) ──────────────────────────
# STORAGE_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# STORAGE_ACCESS_KEY_ID=<R2_ACCESS_KEY_ID>
# STORAGE_SECRET_ACCESS_KEY=<R2_SECRET_ACCESS_KEY>
# STORAGE_BUCKET=dreamlog-audio
# STORAGE_REGION=auto
# STORAGE_USE_PATH_STYLE=false

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Found in Supabase project → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ── OpenAI Whisper ────────────────────────────────────────────────────────────
# For local dev: point at the whisper container — no API key needed.
OPENAI_API_KEY=ignored-for-local-dev
OPENAI_BASE_URL=http://whisper:8000/v1

# For production: point at OpenAI and set a real key.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Local Whisper model size ──────────────────────────────────────────────────
# base  = ~150 MB, fast, good enough for dev
# small = ~500 MB, more accurate
# large-v3 = ~1.5 GB, production quality (slow on CPU)
WHISPER_MODEL=Systran/faster-whisper-base

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Leave blank and set STUB_AI_ANALYSIS=true to skip Claude entirely during dev.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Dev stubs ─────────────────────────────────────────────────────────────────
# STUB_AI_ANALYSIS=true  → worker returns fake analysis, zero Claude API calls
STUB_AI_ANALYSIS=true

# ── Firebase Cloud Messaging ──────────────────────────────────────────────────
# FCM_PROJECT_ID=your-firebase-project-id
# FCM_CREDENTIALS_JSON=<contents of service account JSON, or path to file>

# ── Worker ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=4
WORKER_MAX_RETRIES=3
WORKER_QUEUE_KEY=dreamlog:transcription:queue
WORKER_DLQ_KEY=dreamlog:transcription:dlq
WORKER_POLL_TIMEOUT=5s
